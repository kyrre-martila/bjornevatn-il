{
  "name": "content-website-blueprint",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "turbo run build",
    "build:api": "pnpm --filter ./apps/api build",
    "build:web": "pnpm --filter ./apps/web build",
    "start": "turbo run start --parallel --filter=api --filter=web",
    "start:api": "pnpm --filter api start",
    "start:web": "pnpm --filter web start",
    "api:start:prod": "pnpm --filter api build && node apps/api/dist/main.js",
    "start:api:ci": "node ./apps/api/dist/src/main.js",
    "lint": "eslint . --ext .js,.ts,.tsx",
    "test": "turbo run test",
    "test:unit": "pnpm --filter ./apps/api test",
    "test:contract": "pnpm --filter ./apps/api test:contract",
    "test:e2e:web": "pnpm --filter ./apps/web test:e2e",
    "test:e2e": "node scripts/e2e-auth.test.mjs",
    "smoke:test": "node scripts/smoke-test.mjs",
    "api:openapi": "pnpm generate:openapi",
    "contracts:sync": "pnpm --filter ./packages/contracts run version:bump",
    "sdk:ts": "openapi-generator-cli generate -g typescript-fetch -i packages/contracts/dist/openapi.v1.json -o packages/sdk-ts --additional-properties=useSingleRequestParameter=true,typescriptThreePlus=true",
    "sdk:all": "pnpm api:openapi && pnpm contracts:sync && pnpm sdk:ts",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @blueprint/db exec prisma generate",
    "db:migrate": "pnpm --filter @blueprint/db exec prisma migrate deploy",
    "db:status": "pnpm --filter @blueprint/db exec prisma migrate status",
    "db:resolve:rolled-back": "pnpm --filter @blueprint/db exec prisma migrate resolve --rolled-back",
    "db:push": "pnpm --filter @blueprint/db exec prisma db push",
    "db:seed": "pnpm db:generate && ts-node --transpile-only --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' scripts/seed.ts",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "seed": "pnpm db:seed",
    "generate:openapi": "pnpm --filter api generate:openapi"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@openapitools/openapi-generator-cli": "^2.13.4",
    "eslint": "^9.9.0",
    "playwright": "^1.49.0",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.46.3",
    "wait-on": "^7.2.0"
  },
  "packageManager": "pnpm@10.5.2"
}
