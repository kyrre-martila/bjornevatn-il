# Copy this file to the repository root as `.env` on the production server.
# This file is for non-secret runtime configuration only.
# Keep secrets out of `.env` and store them in `infra/.env.server` instead.

# -----------------------------------------------------------------------------
# Deployment and public URLs
# -----------------------------------------------------------------------------
NODE_ENV=production
DEPLOY_ENV=production
APP_URL=https://www.example.com
NEXT_PUBLIC_SITE_URL=https://www.example.com
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_API_BASE_PATH=/api/v1
INTERNAL_API_URL=http://api:4000
WEB_PORT=3000
API_PORT=4000

# -----------------------------------------------------------------------------
# Database config (non-secret)
# -----------------------------------------------------------------------------
POSTGRES_DB=blueprint
POSTGRES_USER=blueprint

# -----------------------------------------------------------------------------
# Security and app behavior (non-secret)
# -----------------------------------------------------------------------------
API_CORS_ORIGINS=https://www.example.com
TRUST_PROXY=1
NEXT_PUBLIC_CSRF_COOKIE_NAME=XSRF-TOKEN
REGISTRATION_ENABLED=false
NEXT_PUBLIC_REGISTRATION_ENABLED=false
MEDIA_STORAGE_PROVIDER=local
NEXT_PUBLIC_CSP_MEDIA_ORIGINS=

# -----------------------------------------------------------------------------
# Optional email config (host/user are config; password belongs in infra/.env.server)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_FROM="Bjørnevatn IL <no-reply@example.com>"

# -----------------------------------------------------------------------------
# Optional logging / observability config
# -----------------------------------------------------------------------------
LOG_LEVEL=info
METRICS_ALLOWLIST=127.0.0.1/32,::1/128
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=bjornevatn-il-api
OTEL_SERVICE_NAMESPACE=production

# -----------------------------------------------------------------------------
# Optional feature config
# -----------------------------------------------------------------------------
PUBLIC_SUBMISSION_CHALLENGE_TOKEN=
TICKET_ORDER_LOOKUP_TOKEN_TTL_MS=1209600000
LIVE_UPLOADS_PATH=
STAGING_UPLOADS_PATH=
STAGING_SYNC_SCRIPT_PATH=

# -----------------------------------------------------------------------------
# Secrets belong in infra/.env.server (untracked). Required names:
# POSTGRES_PASSWORD
# DATABASE_URL
# JWT_SECRET
# COOKIE_SECRET
# BOOTSTRAP_ADMIN_EMAIL
# BOOTSTRAP_ADMIN_NAME
# BOOTSTRAP_ADMIN_PASSWORD
# SMTP_PASS                # SMTP password secret if email is enabled later
# TICKET_QR_SECRET         # recommended when ticket sales are enabled
# TICKET_ORDER_LOOKUP_SECRET
# LIVE_DATABASE_URL        # only for staging sync operations
# STAGING_DATABASE_URL     # only for staging sync operations
# STAGING_PUSH_CONFIRMATION_TOKEN
# -----------------------------------------------------------------------------
