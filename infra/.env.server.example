# Copy this file to `infra/.env.server` on the production server.
# This file is secret-only and must never be committed.

POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://blueprint:replace-with-a-long-random-password@db:5432/blueprint?schema=public
JWT_SECRET=replace-with-a-random-32-plus-char-secret
COOKIE_SECRET=replace-with-a-different-random-32-plus-char-secret
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_NAME=Production Administrator
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-bootstrap-password

# Optional secret values
SMTP_PASS=
TICKET_QR_SECRET=
TICKET_ORDER_LOOKUP_SECRET=
LIVE_DATABASE_URL=
STAGING_DATABASE_URL=
STAGING_PUSH_CONFIRMATION_TOKEN=
