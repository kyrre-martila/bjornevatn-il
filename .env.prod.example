# Example values only; replace all secrets before deploying.
NODE_ENV=production
# Optional but recommended: explicitly mark deployment tier. `staging` is treated with production guardrails.
DEPLOY_ENV=production
NEXT_PUBLIC_SITE_URL=https://app.example.com
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_API_BASE_PATH=/api/v1
NEXT_PUBLIC_CSP_MEDIA_ORIGINS=
DATABASE_URL=postgresql://example-user:example-password@db:5432/app?schema=public
JWT_SECRET=***required-random-32-plus-chars-with-mixed-types***
COOKIE_SECRET=***required-random-32-plus-chars-with-mixed-types***
API_CORS_ORIGINS=https://app.example.com,https://admin.example.com
CSRF_COOKIE_NAME=XSRF-TOKEN
REGISTRATION_ENABLED=false
NEXT_PUBLIC_REGISTRATION_ENABLED=false
