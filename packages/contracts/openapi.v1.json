            "type": "string",
            "format": "date-time"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "phone",
          "firstName",
          "lastName",
          "birthDate",
          "displayName",
          "createdAt",
          "role"
        ]
      },
      "MeResponseDto": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserProfileDto"
          }
        },
        "required": ["user"]
      },
      "MagicLinkResponseDto": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          }
        },
        "required": ["ok"]
      },
      "TokenPairResponseDto": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          }
        },
        "required": ["ok", "accessToken", "refreshToken"]
      }
    }
