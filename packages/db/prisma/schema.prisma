generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  admin
  editor
}

enum WorkflowStatus {
  draft
  in_review
  approved
  published
  archived
}

enum SiteEnvironmentName {
  live
  staging
}

enum SiteEnvironmentState {
  active
  stale
  deleted
}

enum SiteEnvironmentLockStatus {
  idle
  syncing
  pushing
  deleting
}

enum ClubhouseBookingStatus {
  pending
  approved
  rejected
  cancelled
}

enum TicketSaleStatus {
  draft
  active
  sold_out
  closed
}

enum TicketStatus {
  reserved
  confirmed
  cancelled
  used
}

enum MembershipApplicationStatus {
  new
  contacted
  approved
  rejected
  archived
}

model User {
  id                  String                  @id @default(cuid())
  email               String                  @unique
  phone               String?                 @unique
  name                String?
  firstName           String                  @default("")
  lastName            String                  @default("")
  birthDate           DateTime?
  passwordHash        String? // null tillates fortsatt for magic-link-brukere
  acceptedTerms       Boolean                 @default(false)
  displayName         String?
  role                UserRole                @default(editor)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  createdBy           String?                 @db.VarChar(255)
  updatedBy           String?                 @db.VarChar(255)
  credentials         Credential[]
  sessions            Session[]
  auditLogs           AuditLog[]
  environmentStatuses SiteEnvironmentStatus[]

  @@index([firstName, lastName])
  @@index([email])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([entityType])
  @@index([action])
}

model Credential {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String
  publicKey Bytes
  counter   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?  @db.VarChar(255)
  updatedBy String?  @db.VarChar(255)
}

model Session {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  token     String    @unique
  ip        String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.VarChar(255)
  updatedBy String?   @db.VarChar(255)
  expiresAt DateTime
  revokedAt DateTime?

  @@index([token])
}

model MagicLink {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.VarChar(255)
  updatedBy String?   @db.VarChar(255)

  @@index([email])
}

model Page {
  id             String             @id @default(cuid())
  slug           String             @unique
  title          String
  seoTitle       String?
  seoDescription String?
  seoImage       String?
  canonicalUrl   String?
  noIndex        Boolean            @default(false)
  published      Boolean            @default(false)
  workflowStatus WorkflowStatus     @default(draft)
  publishAt      DateTime?
  unpublishAt    DateTime?
  templateKey    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  blocks         PageBlock[]
  slugRedirects  PageSlugRedirect[]
  revisions      PageRevision[]

  @@index([slug])
  @@index([published])
}

model PageRevision {
  id           String   @id @default(cuid())
  pageId       String
  page         Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  snapshot     Json
  revisionNote String?
  createdById  String?
  createdAt    DateTime @default(now())

  @@index([pageId, createdAt])
}

model PageSlugRedirect {
  id         String   @id @default(cuid())
  pageId     String
  page       Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  sourceSlug String   @unique
  createdAt  DateTime @default(now())

  @@index([pageId])
}

model PageBlock {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      String
  data      Json
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageId])
  @@index([pageId, order])
}

model ContentType {
  id            String                    @id @default(cuid())
  name          String
  slug          String                    @unique
  description   String
  isPublic      Boolean                   @default(true)
  fields        Json                      @default("[]")
  templateKey   String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  items         ContentItem[]
  slugRedirects ContentItemSlugRedirect[]

  @@index([slug])
}

model ContentItem {
  id             String                    @id @default(cuid())
  contentTypeId  String
  contentType    ContentType               @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)
  parentId       String?
  parent         ContentItem?              @relation("ContentItemTree", fields: [parentId], references: [id], onDelete: SetNull)
  children       ContentItem[]             @relation("ContentItemTree")
  sortOrder      Int                       @default(0)
  slug           String
  title          String
  seoTitle       String?
  seoDescription String?
  seoImage       String?
  canonicalUrl   String?
  noIndex        Boolean                   @default(false)
  data           Json
  published      Boolean                   @default(false)
  workflowStatus WorkflowStatus            @default(draft)
  publishAt      DateTime?
  unpublishAt    DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  slugRedirects  ContentItemSlugRedirect[]
  terms          ContentItemTerm[]
  revisions      ContentItemRevision[]
  ticketSale     TicketSale?

  @@unique([contentTypeId, slug])
  @@index([contentTypeId])
  @@index([parentId])
  @@index([contentTypeId, parentId, sortOrder])
  @@index([published])
}

model TicketSale {
  id          String           @id @default(cuid())
  matchId     String           @unique
  match       ContentItem      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  title       String
  description String?
  ticketTypes Json
  saleStartAt DateTime
  saleEndAt   DateTime
  maxTickets  Int
  status      TicketSaleStatus @default(draft)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tickets     Ticket[]

  @@index([status, saleStartAt, saleEndAt])
}

model Ticket {
  id             String       @id @default(cuid())
  ticketSaleId   String
  ticketSale     TicketSale   @relation(fields: [ticketSaleId], references: [id], onDelete: Cascade)
  ticketType     String
  buyerName      String
  buyerEmail     String
  buyerPhone     String
  quantity       Int
  status         TicketStatus @default(reserved)
  orderReference String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([ticketSaleId, ticketType])
  @@index([orderReference])
  @@index([status])
}

model ContentItemRevision {
  id            String      @id @default(cuid())
  contentItemId String
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  snapshot      Json
  revisionNote  String?
  createdById   String?
  createdAt     DateTime    @default(now())

  @@index([contentItemId, createdAt])
}

model ContentItemSlugRedirect {
  id            String      @id @default(cuid())
  contentItemId String
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  contentTypeId String
  contentType   ContentType @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)
  sourceSlug    String
  createdAt     DateTime    @default(now())

  @@unique([contentTypeId, sourceSlug])
  @@index([contentItemId])
}

model ClubhouseBooking {
  id            String                 @id @default(cuid())
  bookedByName  String
  bookedByEmail String
  bookedByPhone String
  organization  String?
  purpose       String
  attendeeCount Int?
  startAt       DateTime
  endAt         DateTime
  status        ClubhouseBookingStatus @default(pending)
  adminNotes    String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([startAt, endAt])
  @@index([status, startAt, endAt])
}

model ClubhouseBlockedPeriod {
  id        String   @id @default(cuid())
  startAt   DateTime
  endAt     DateTime
  reason    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startAt, endAt])
}

model MembershipSettings {
  id                   String   @id @default("membership-settings")
  pageTitle            String
  introText            String
  benefitsTitle        String
  benefits             Json
  categoriesTitle      String
  applicationTitle     String
  confirmationTitle    String?
  confirmationText     String?
  contactEmail         String?
  showBenefitsSection  Boolean  @default(true)
  showCategoriesSection Boolean @default(true)
  showApplicationForm  Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model MembershipCategory {
  id           String                  @id @default(cuid())
  name         String
  slug         String                  @unique
  description  String
  priceLabel   String
  ageGroup     String
  sortOrder    Int                     @default(0)
  isActive     Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  applications MembershipApplication[]

  @@index([isActive, sortOrder])
}

model MembershipApplication {
  id                   String                      @id @default(cuid())
  fullName             String
  email                String
  phone                String?
  dateOfBirth          DateTime?
  addressLine          String?
  postalCode           String?
  city                 String?
  guardianName         String?
  guardianPhone        String?
  guardianEmail        String?
  membershipCategoryId String
  membershipCategory   MembershipCategory          @relation(fields: [membershipCategoryId], references: [id], onDelete: Restrict)
  notes                String?
  status               MembershipApplicationStatus @default(new)
  adminNotes           String?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  @@index([membershipCategoryId])
  @@index([status, createdAt])
}

model NavigationItem {
  id       String           @id @default(cuid())
  label    String
  url      String
  order    Int
  parentId String?
  parent   NavigationItem?  @relation("NavigationTree", fields: [parentId], references: [id], onDelete: SetNull)
  children NavigationItem[] @relation("NavigationTree")

  @@index([order])
  @@index([parentId])
}

model RedirectRule {
  id         String   @id @default(cuid())
  fromPath   String   @unique
  toPath     String
  statusCode Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([fromPath])
}

model SiteSetting {
  key   String @id
  value String
}

model SiteEnvironmentStatus {
  environment     SiteEnvironmentName       @id
  state           SiteEnvironmentState      @default(active)
  lastSyncedAt    DateTime?
  lastPushedAt    DateTime?
  lastResetAt     DateTime?
  lockStatus      SiteEnvironmentLockStatus @default(idle)
  lastActorUserId String?
  lastActorUser   User?                     @relation(fields: [lastActorUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([lastActorUserId])
  @@index([lockStatus])
}

model Media {
  id               String   @id @default(cuid())
  url              String
  alt              String
  width            Int?
  height           Int?
  mimeType         String?
  sizeBytes        Int?
  originalFilename String?
  storageKey       String?
  createdAt        DateTime @default(now())
}

model Taxonomy {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  terms       Term[]

  @@index([slug])
}

model Term {
  id           String            @id @default(cuid())
  taxonomyId   String
  taxonomy     Taxonomy          @relation(fields: [taxonomyId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  description  String
  parentId     String?
  parent       Term?             @relation("TermTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     Term[]            @relation("TermTree")
  createdAt    DateTime          @default(now())
  contentItems ContentItemTerm[]

  @@unique([taxonomyId, slug])
  @@index([taxonomyId])
  @@index([parentId])
}

model ContentItemTerm {
  contentItemId String
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  termId        String
  term          Term        @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@id([contentItemId, termId])
  @@index([termId])
}
