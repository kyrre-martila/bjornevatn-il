# Copy to .env.prod (or .env) before deploying. Do not commit real secrets.

# -----------------------------------------------------------------------------
# Deployment and public URLs
# Mandatory in production.
# -----------------------------------------------------------------------------
NODE_ENV=production
DEPLOY_ENV=production
APP_URL=https://www.example.com
NEXT_PUBLIC_SITE_URL=https://www.example.com
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_API_BASE_PATH=/api/v1
INTERNAL_API_URL=http://api:4000
WEB_PORT=3000
API_PORT=4000

# -----------------------------------------------------------------------------
# Database
# Mandatory in production.
# -----------------------------------------------------------------------------
POSTGRES_DB=blueprint
POSTGRES_USER=blueprint
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://blueprint:replace-with-a-long-random-password@db:5432/blueprint?schema=public

# -----------------------------------------------------------------------------
# Auth/session/security
# Mandatory in production.
# Use randomly generated values with at least 32 chars.
# -----------------------------------------------------------------------------
JWT_SECRET=replace-with-a-random-32-plus-char-secret
COOKIE_SECRET=replace-with-a-different-random-32-plus-char-secret
API_CORS_ORIGINS=https://www.example.com
TRUST_PROXY=1
NEXT_PUBLIC_CSRF_COOKIE_NAME=XSRF-TOKEN
REGISTRATION_ENABLED=false
NEXT_PUBLIC_REGISTRATION_ENABLED=false
PUBLIC_SUBMISSION_CHALLENGE_TOKEN=

# -----------------------------------------------------------------------------
# Media/storage
# Mandatory for this Docker deployment strategy.
# Local storage is the only implemented production-capable provider today.
# -----------------------------------------------------------------------------
MEDIA_STORAGE_PROVIDER=local
NEXT_PUBLIC_CSP_MEDIA_ORIGINS=

# -----------------------------------------------------------------------------
# Email (optional unless password reset / email features are used)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Bjørnevatn IL <no-reply@example.com>"

# -----------------------------------------------------------------------------
# Tickets / public order lookup (recommended when ticket sales are enabled)
# -----------------------------------------------------------------------------
TICKET_QR_SECRET=
TICKET_ORDER_LOOKUP_SECRET=
TICKET_ORDER_LOOKUP_TOKEN_TTL_MS=1209600000

# -----------------------------------------------------------------------------
# Logging / observability (optional)
# -----------------------------------------------------------------------------
LOG_LEVEL=info
METRICS_ALLOWLIST=127.0.0.1/32,::1/128
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=bjornevatn-il-api
OTEL_SERVICE_NAMESPACE=production

# -----------------------------------------------------------------------------
# Optional staging sync features. Leave blank unless you use the staging module.
# -----------------------------------------------------------------------------
LIVE_DATABASE_URL=
STAGING_DATABASE_URL=
LIVE_UPLOADS_PATH=
STAGING_UPLOADS_PATH=
STAGING_PUSH_CONFIRMATION_TOKEN=
STAGING_SYNC_SCRIPT_PATH=
