# Example values only; replace all secrets before deploying.
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_BASE_PATH=/api/v1
API_PORT=4000
DATABASE_URL=postgresql://example-user:example-password@localhost:5432/appdb?schema=public
PRISMA_MIGRATIONS=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=change-me
SMTP_PASS=change-me
SMTP_FROM="Blueprint <no-reply@local.test>"
JWT_ISS=blueprint
JWT_AUD=blueprint-web
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=1209600
JWT_SECRET=change-me-jwt-secret
COOKIE_SECRET=change-me-cookie-secret
ENCRYPTION_KEY=change-me-encryption-key
COOKIE_DOMAIN=
API_CORS_ORIGINS=http://localhost:3000,https://app.example.com
CSRF_COOKIE_NAME=XSRF-TOKEN
LOG_LEVEL=info
METRICS_ALLOWLIST=127.0.0.1/32
METRICS_USER=metrics
METRICS_PASS=example-metrics-password
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=api
OTEL_SERVICE_NAMESPACE=blueprint
APP_VERSION=0.0.0
OTEL_TRACES_SAMPLER=traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
